@article{Bennert2002,
	doi = {10.1086/342420},
	url = {https://doi.org/10.1086/342420},
	year = 2002,
	month = {aug},
	publisher = {American Astronomical Society},
	volume = {574},
	number = {2},
	pages = {L105--L109},
	author = {Nicola Bennert and Heino Falcke and Hartmut Schulz and Andrew S. Wilson and Beverley J. Wills},
	title = {Size and Structure of the Narrow-Line Region of Quasars},
	journal = {The Astrophysical Journal},
	abstract = {We have observed the narrow-line regions (NLRs) of the seven brightest radio-quiet Palomar-Green (or Bright Quasar Survey) quasars (z < 0.5) with the Wide Field Planetary Camera 2 on board the Hubble Space Telescope (HST). Linear-ramp filters were used to image the [O III] λ5007 line emission with 0.″0455-0.″1 pixel resolution. We find that the NLRs are very compact with typical extents of 2''-4''. Two quasars show compact filamentary structures similar to Seyfert NLRs. They may be related to radio outflows. Most interestingly, when including a sample of Seyfert galaxies observed with HST, we tentatively find that the size of the NLR is proportional to the square root of the [O III] luminosity. This is comparable to the scaling found for the size of the broad-line region with continuum luminosity, which has been interpreted in terms of a constant photoionization parameter. The relation determined here connects the NLR of radio-quiet quasars and Seyfert galaxies over 3 orders of magnitude in [O III] luminosity.}
}

